# Flask
FLASK_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_SECRET_KEY=another-random-64-char-string-here

# Twilio (WhatsApp / SMS intruder alert)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM=+14155238886
TWILIO_TO=+91XXXXXXXXXX

# SMTP (email intruder alert)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=alert.recipient@gmail.com

# Paths
VOICE_SAMPLES_DIR=./data/voice_samples
INTRUDER_SNAPSHOTS_DIR=./data/intruder_snapshots
INCIDENT_LOG=./data/incidents.log

# ── Lovable Cloud (shared Supabase backend) ──────────────────────────────────
# These values come from the Lovable Cloud project. The SERVICE_ROLE key
# bypasses Row-Level Security and MUST stay server-side. The Python backend
# uses it to write auth_attempts / audit_log / intruder_events / sessions /
# hardware_fingerprints rows on behalf of the owner.
SUPABASE_URL=https://llwkowocacvwkssrnsgg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-from-lovable-cloud-settings
SUPABASE_OWNER_ID=paste-owner-uuid-after-web-setup

# Toggle cloud sync (set to false for fully air-gapped operation)
JARVIS_CLOUD_SYNC=true
